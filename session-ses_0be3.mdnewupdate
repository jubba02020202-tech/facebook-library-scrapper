{
  "filePath": "C:\\Users\\SomaliRank\\Desktop\\dubia store\\facebook scapper\\src\\services\\facebookAdsScraper.js",
  "content": "const { chromium } = require('playwright');\nconst config = require('../config');\nconst { extractPhonesFromText, extractWhatsAppLinks } = require('../utils/phoneExtractor');\n\nconst LOG_PREFIX = '[FB]';\n\nclass FacebookAdsScraper {\n\n  async scrape(adsUrl, onProgress) {\n    console.log(`${LOG_PREFIX} Starting...`);\n    console.log(`${LOG_PREFIX} URL: ${adsUrl}`);\n\n    const browser = await chromium.launch({\n      headless: config.facebook.headless,\n      args: [\n        '--disable-blink-features=AutomationControlled',\n        '--no-sandbox',\n      ],\n    });\n\n    const context = await browser.newContext({\n      userAgent: config.userAgent,\n      viewport: { width: 1920, height: 1080 },\n      locale: 'en-US',\n      bypassCSP: true,\n    });\n\n    await context.addInitScript(() => {\n      delete Object.getPrototypeOf(navigator).webdriver;\n      Object.defineProperty(navigator, 'platform', { get: () => 'Win32' });\n    });\n\n    const page = await context.newPage();\n\n    page.on('response', (resp) => {\n      if (resp.status() === 429) console.log(`${LOG_PREFIX} Rate limited (429): ${resp.url().substring(0, 80)}`);\n    });\n\n    try {\n      console.log(`${LOG_PREFIX} Navigating...`);\n      await page.goto(adsUrl, { waitUntil: 'domcontentloaded', timeout: 90000 });\n      await page.waitForTimeout(5000);\n\n      await this._handlePopups(page);\n\n      const hasLogin = await this._checkLoginWall(page);\n      if (hasLogin) {\n        console.log(`${LOG_PREFIX} LOGIN REQUIRED - Waiting for manual login...`);\n        for (let i = 0; i < 60; i++) {\n          if (onProgress) {\n            onProgress({\n              step: 'facebook', adsFound: 0, scrolls: 0,\n              message: `Please log in to Facebook in the browser window... (${i * 3}s)`,\n            });\n          }\n          await page.waitForTimeout(3000);\n          if (!(await this._checkLoginWall(page))) {\n            console.log(`${LOG_PREFIX} Login detected!`);\n            break;\n          }\n        }\n      }\n\n      await page.waitForTimeout(2000);\n\n      console.log(`${LOG_PREFIX} Scrolling to load ALL ads...`);\n      const totalScrolls = await this._scrollAll(page, onProgress);\n      console.log(`${LOG_PREFIX} Scroll complete (${totalScrolls} scrolls)`);\n\n      console.log(`${LOG_PREFIX} Extracting ads from page text...`);\n      const ads = await this._extractFromPageText(page);\n\n      console.log(`${LOG_PREFIX} Extracted ${ads.length} ads total`);\n\n      if (ads.length > 0) {\n        const sample = ads.slice(0, 3).map(a => `${a.businessName}: website=${a.websiteUrl}, phones=${a.phones?.length || 0}`);\n        console.log(`${LOG_PREFIX} Samples:`, JSON.stringify(sample));\n      }\n\n      console.log(`${LOG_PREFIX} Opening ad details for website URLs & CTAs...`);\n      const enrichedAds = await this._enrichWithDetails(page, ads, onProgress);\n\n      console.log(`${LOG_PREFIX} Final: ${enrichedAds.length} ads enriched`);\n      return enrichedAds;\n\n    } catch (err) {\n      console.error(`${LOG_PREFIX} Fatal:`, err.message);\n      throw err;\n    } finally {\n      await browser.close();\n    }\n  }\n\n  async _handlePopups(page) {\n    const patterns = [\n      'button:has-text(\"Allow\")',\n      'button:has-text(\"Accept\")',\n      'button:has-text(\"OK\")',\n      '[aria-label=\"Close\"]',\n    ];\n    for (const sel of patterns) {\n      try {\n        const el = page.locator(sel).first();\n        if (await el.count() > 0) {\n          await el.click({ timeout: 2000 });\n          await page.waitForTimeout(500);\n          console.log(`${LOG_PREFIX} Closed popup: ${sel}`);\n        }\n      } catch {}\n    }\n  }\n\n  async _checkLoginWall(page) {\n    return page.evaluate(() => {\n      const t = document.body.innerText || '';\n      return t.includes('Log in') && t.includes('Email') && t.includes('Password');\n    });\n  }\n\n  async _scrollAll(page, onProgress) {\n    const maxScrolls = config.facebook.maxScrolls;\n    let prevHeight = await page.evaluate(() => document.body.scrollHeight);\n    let sameCount = 0;\n\n    for (let i = 0; i < maxScrolls; i++) {\n      await page.evaluate(() => {\n        const main = document.querySelector('div[role=\"main\"]');\n        if (main) main.scrollTop = main.scrollHeight;\n        else window.scrollBy(0, 1500);\n      });\n\n      await page.waitForTimeout(config.facebook.scrollDelay);\n\n      const newHeight = await page.evaluate(() => document.body.scrollHeight);\n      if (newHeight === prevHeight) {\n        sameCount++;\n        if (sameCount >= 5) break;\n      } else {\n        sameCount = 0;\n        prevHeight = newHeight;\n      }\n\n      if (onProgress) {\n        onProgress({\n          step: 'facebook', adsFound: i + 1, scrolls: i + 1,\n          message: `Scrolling to load all ads... (scroll ${i + 1})`,\n        });\n      }\n    }\n    return maxScrolls;\n  }\n\n  async _extractFromPageText(page) {\n    const raw = await page.evaluate(() => {\n      const main = document.querySelector('div[role=\"main\"]');\n      return (main ? main.innerText : document.body.innerText) || '';\n    });\n\n    const blocks = raw.split('See ad details').filter(b => b.trim().length > 50);\n    console.log(`${LOG_PREFIX} Found ${blocks.length} ad blocks in text`);\n\n    const ads = [];\n\n    for (const block of blocks) {\n      try {\n        const lines = block.split('\\n').map(l => l.trim()).filter(l => l.length > 0);\n\n        const sponsoredIdx = lines.findIndex(l => l.toLowerCase() === 'sponsored');\n        const businessName = sponsoredIdx > 0 ? lines[sponsoredIdx - 1] : (lines[0] || 'Unknown');\n        const descriptionLines = sponsoredIdx >= 0 ? lines.slice(sponsoredIdx + 1) : lines;\n\n        const fullText = descriptionLines.join(' ');\n\n        const urlRegex = /https?:\\/\\/[^\\s,]+/g;\n        const urls = fullText.match(urlRegex) || [];\n        const websiteUrl = urls.find(u =>\n          !u.includes('facebook.com') && !u.includes('fb.com') &&\n          !u.includes('whatsapp.com') && !u.includes('wa.me') &&\n          !u.includes('api.whatsapp') && !u.includes('metastatus')\n        ) || '';\n\n        const phones = extractPhonesFromText(fullText);\n        const waLinks = extractWhatsAppLinks(fullText);\n\n        const ctaKeywords = ['shop now', 'book now', 'order now', 'buy now',\n          'visit website', 'learn more', 'sign up', 'get started',\n          'contact us', 'watch now', 'download', 'apply now'];\n        const cta = ctaKeywords.find(k => fullText.toLowerCase().includes(k)) || '';\n\n        const hasSponsoredLine = lines.some(l => l.toLowerCase() === 'sponsored');\n        const adLinkMatch = block.match(/Library ID:\\s*(\\d+)/);\n        const adLink = adLinkMatch ? `https://www.facebook.com/ads/library/ad/?id=${adLinkMatch[1]}` : '';\n\n        if (businessName && businessName.length > 1 && hasSponsoredLine) {\n          ads.push({\n            businessName,\n            pageName: businessName,\n            websiteUrl: websiteUrl || '',\n            cta: cta || '',\n            adLink,\n            phones,\n            whatsappLinks: waLinks,\n          });\n        }\n      } catch (err) {\n        console.log(`${LOG_PREFIX} Parse error for block: ${err.message}`);\n      }\n    }\n\n    const unique = [];\n    const seen = new Set();\n    for (const ad of ads) {\n      const key = ad.businessName.toLowerCase();\n      if (!seen.has(key)) {\n        seen.add(key);\n        unique.push(ad);\n      }\n    }\n\n    console.log(`${LOG_PREFIX} Unique businesses: ${unique.length}`);\n    return unique;\n  }\n\n  async _enrichWithDetails(page, ads, onProgress) {\n    const enriched = [];\n    const total = ads.length;\n\n    for (let i = 0; i < total; i++) {\n      if (onProgress) {\n        onProgress({\n          step: 'facebook_details', adsFound: enriched.length,\n          current: i + 1, total,\n          message: `Opening ad details ${i + 1}/${total}...`,\n        });\n      }\n\n      const ad = ads[i];\n      try {\n        const detail = await this._openAdDetail(page, ad);\n        if (detail) {\n          enriched.push({\n            ...ad,\n            websiteUrl: detail.websiteUrl || ad.websiteUrl,\n            cta: detail.cta || ad.cta,\n          });\n        } else {\n          enriched.push(ad);\n        }\n      } catch {\n        enriched.push(ad);\n      }\n\n      await page.waitForTimeout(300);\n    }\n\n    return enriched;\n  }\n\n  async _openAdDetail(page, ad) {\n    if (!ad.adLink) return null;\n\n    try {\n      const newPage = await page.context().newPage();\n      await newPage.goto(ad.adLink, { waitUntil: 'domcontentloaded', timeout: 20000 });\n      await newPage.waitForTimeout(2000);\n\n      const detail = await newPage.evaluate(() => {\n        const text = document.body.innerText || '';\n        const links = document.querySelectorAll('a');\n        let websiteUrl = '';\n        let cta = '';\n\n        links.forEach((a) => {\n          const href = a.getAttribute('href') || '';\n          const txt = (a.textContent || '').trim().toLowerCase();\n\n          if (!href.includes('facebook.com') && !href.includes('fb.com') &&\n              !href.includes('metastatus') && !href.includes('whatsapp') &&\n              (href.startsWith('http://') || href.startsWith('https://'))) {\n            if (!websiteUrl) websiteUrl = href;\n          }\n\n          const ctaWords = ['shop', 'book', 'get', 'order', 'buy', 'visit',\n            'apply', 'register', 'donate', 'sign up', 'see', 'watch', 'contact',\n            'learn', 'download', 'try', 'start', 'join'];\n          if (!cta && txt && txt.length < 40) {\n            for (const w of ctaWords) {\n              if (txt === w || txt.startsWith(w)) {\n                cta = a.textContent.trim();\n                break;\n              }\n            }\n          }\n        });\n\n        const heading = document.querySelector('h1, h2, h3');\n        const businessName = heading ? heading.textContent.trim() : '';\n        const pageName = businessName;\n\n        return { businessName, pageName, websiteUrl, cta };\n      });\n\n      await newPage.close();\n      return detail;\n\n    } catch (err) {\n      console.log(`${LOG_PREFIX} Detail page error: ${err.message}`);\n      return null;\n    }\n  }\n}\n\nmodule.exports = FacebookAdsScraper;\n"
}
