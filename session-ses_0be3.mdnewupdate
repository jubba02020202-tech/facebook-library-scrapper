182:   _getUniqueWebsites(ads) {
183:     const seen = new Set();
184:     const unique = [];
185:     for (const ad of ads) {
186:       const url = normalizeUrl(ad.websiteUrl) || ad.websiteUrl;
187:       const key = url || ad.adLink;
188:       if (!seen.has(key)) {
189:         seen.add(key);
190:         unique.push(ad);
191:       }
192:     }
193:     return unique;
194:   }
195: 
196:   generateExport(sessionId) {
197:     const session = this.sessions.get(sessionId);
198:     if (!session) throw new Error('Session not found');
199: 
200:     const content = this.exportService.toTxt(session.results);
201:     const fileName = this.exportService.saveToFile(content, sessionId);
202:     session.exportFileName = fileName;
203:     return fileName;
204:   }
205: }
