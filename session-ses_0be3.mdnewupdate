{
  "filePath": "C:\\Users\\SomaliRank\\Desktop\\dubia store\\facebook scapper\\src\\utils\\phoneExtractor.js",
  "content": "const { parsePhoneNumberFromString } = require('libphonenumber-js');\n\nconst LABEL_REGEX = /(\\b[a-zA-Z\\u0600-\\u06FF\\u00C0-\\u024F]{2,30}?)\\s*[:]\\s*([\\+\\d\\s\\-\\.\\(\\)]{6,})/g;\nconst PHONE_ONLY = /(?:\\+?\\d{1,4}[-.\\s]?)?\\(?\\d{2,4}\\)?[-.\\s]?\\d{2,4}[-.\\s]?\\d{2,9}(?:[-.\\s]?\\d{2,9})?/g;\n\nconst KNOWN_LABELS = [\n  'wac', 'call', 'tel', 'phone', 'mobile', 'whatsapp', 'wa', 'contact',\n  'soo wac', 'nagala soo xiriir', 'nagala soo xaririir', 'xiriir',\n  'dalbo', 'order', 'customer', 'support', 'help', 'line', 'number',\n  'telephone', 'cell', 'hotline', 'landline', 'office', 'direct',\n];\n\nfunction extractPhonesFromText(text) {\n  if (!text) return [];\n  const results = [];\n  const seen = new Set();\n\n  const labelMatches = [];\n  let m;\n  while ((m = LABEL_REGEX.exec(text)) !== null) {\n    const label = m[1].trim();\n    const rawNumber = m[2].trim();\n    const cleaned = rawNumber.replace(/[^\\d+]/g, '');\n    const digits = cleaned.replace(/\\D/g, '');\n    if (digits.length < 6 || digits.length > 15) continue;\n\n    const normalized = normalizeToE164(cleaned);\n    const key = normalized.replace(/\\D/g, '');\n\n    if (!seen.has(key)) {\n      seen.add(key);\n      labelMatches.push({ label, raw: rawNumber, number: normalized, key });\n    }\n  }\n\n  const plainMatches = text.match(PHONE_ONLY) || [];\n  for (const match of plainMatches) {\n    const cleaned = match.replace(/[^\\d+]/g, '');\n    const digits = cleaned.replace(/\\D/g, '');\n    if (digits.length < 6 || digits.length > 15) continue;\n\n    const normalized = normalizeToE164(cleaned);\n    const key = normalized.replace(/\\D/g, '');\n\n    if (seen.has(key)) continue;\n    seen.add(key);\n\n    const lower = text.substring(0, text.indexOf(match)).toLowerCase();\n    let label = '';\n    for (const known of KNOWN_LABELS) {\n      if (lower.endsWith(known) || lower.endsWith(known + ' ')) {\n        label = known;\n        break;\n      }\n    }\n\n    if (label) {\n      labelMatches.push({ label, raw: match, number: normalized, key });\n    } else {\n      results.push({ label: '', full: normalized });\n    }\n  }\n\n  for (const lm of labelMatches) {\n    results.push({ label: lm.label, full: lm.number });\n  }\n\n  return results;\n}\n\nfunction extractWhatsAppLinks(text) {\n  if (!text) return [];\n  const results = [];\n  const seen = new Set();\n\n  const regex = /(?:https?:\\/\\/)?(?:wa\\.me|whatsapp\\.com)\\/(?:send\\/?)?(?:\\?phone=)?([\\d\\s\\-\\.\\+]+)/gi;\n  while ((m = regex.exec(text)) !== null) {\n    const raw = m[1].replace(/[\\s\\-\\.]/g, '');\n    if (raw.length < 6) continue;\n    const num = raw.replace(/^\\+/, '');\n    const key = num.replace(/\\D/g, '');\n    if (seen.has(key)) continue;\n    seen.add(key);\n\n    const lowerBefore = text.substring(0, m.index).toLowerCase();\n    let label = 'WhatsApp';\n    for (const known of ['whatsapp', 'wa', 'watsapp']) {\n      if (lowerBefore.includes(known)) {\n        label = known.charAt(0).toUpperCase() + known.slice(1);\n        break;\n      }\n    }\n\n    results.push({\n      label,\n      phone: '+' + num,\n      link: 'https://wa.me/' + num,\n    });\n  }\n\n  return results;\n}\n\nfunction normalizeToE164(numberStr) {\n  const cleaned = numberStr.replace(/[^\\d+]/g, '');\n  const digits = cleaned.replace(/\\D/g, '');\n\n  if (cleaned.startsWith('+')) return cleaned;\n\n  if (digits.length === 9 && (digits.startsWith('6') || digits.startsWith('7'))) {\n    return '+252' + digits;\n  }\n\n  if (digits.length === 8 && (digits.startsWith('6') || digits.startsWith('7'))) {\n    return '+252' + digits;\n  }\n\n  if (digits.length === 12 && digits.startsWith('252')) {\n    return '+' + digits;\n  }\n\n  if (digits.length === 10 && digits.startsWith('0')) {\n    const withoutZero = digits.substring(1);\n    if (withoutZero.startsWith('6') || withoutZero.startsWith('7')) {\n      return '+252' + withoutZero;\n    }\n  }\n\n  return '+' + digits;\n}\n\nfunction deduplicatePhones(phones) {\n  const seen = new Set();\n  return phones.filter((p) => {\n    const full = typeof p === 'string' ? p : p.full;\n    const key = full.replace(/\\D/g, '');\n    const normalized = normalizeToE164(full).replace(/\\D/g, '');\n    const finalKey = normalized;\n    if (seen.has(finalKey)) return false;\n    seen.add(finalKey);\n    if (key !== finalKey) seen.add(key);\n    return true;\n  });\n}\n\nfunction mergeAllPhones(phoneArrays) {\n  const all = phoneArrays.flat();\n  return deduplicatePhones(all);\n}\n\nfunction displayPhones(phones) {\n  if (!phones || phones.length === 0) return '';\n  return phones.map((p) => {\n    const label = p.label || '';\n    const number = p.full || p;\n    return label ? `${label}: ${number}` : number;\n  });\n}\n\nmodule.exports = {\n  extractPhonesFromText, extractWhatsAppLinks,\n  deduplicatePhones, mergeAllPhones,\n  displayPhones,\n};\n"
}
