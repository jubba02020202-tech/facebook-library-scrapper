esults.articleRoles = [];\n    document.querySelectorAll('[role=\"article\"]').forEach(el => {\n      results.articleRoles.push({\n        tag: el.tagName,\n        className: (el.className || '').substring(0, 60),\n        text: (el.textContent || '').substring(0, 100),\n      });\n    });\n\n    // Check role=\"main\"\n    results.mainRoles = [];\n    document.querySelectorAll('[role=\"main\"]').forEach(el => {\n      results.mainRoles.push({\n        tag: el.tagName,\n        className: (el.className || '').substring(0, 60),\n        children: el.children.length,\n        text: (el.textContent || '').substring(0, 150),\n      });\n    });\n\n    // Check role=\"list\" or role=\"listitem\"\n    results.listRoles = [];\n    document.querySelectorAll('[role=\"list\"], [role=\"listitem\"]').forEach(el => {\n      const r = el.getAttribute('role') || '';\n      results.listRoles.push({\n        tag: el.tagName,\n        role: r,\n        className: (el.className || '').substring(0, 60),\n        text: (el.textContent || '').substring(0, 100),\n      });\n      if (results.listRoles.length > 10) return;\n    });\n\n    // Find elements containing 'Sponsored' text\n    const sponsoredElements = [];\n    allElements.forEach((el) => {\n      if (el.tagName === 'DIV' || el.tagName === 'SECTION') {\n        const text = el.textContent || '';\n        if (text.includes('Sponsored') && text.length > 100 && text.length < 8000) {\n          const parent = el.closest('div');\n          sponsoredElements.push({\n            tag: el.tagName,\n            className: (el.className || '').substring(0, 80),\n            role: el.getAttribute('role') || '',\n            parentClasses: parent ? (parent.className || '').substring(0, 80) : '',\n            textLength: text.length,\n            text: text.substring(0, 400),\n          });\n          if (sponsoredElements.length >= 5) return;\n        }\n      }\n    });\n    results.sponsoredElements = sponsoredElements;\n\n    // Get the first few 'See ad details' parent links (they might be <a> tags)\n    const adLinks = [];\n    document.querySelectorAll('a[href*=\"/ads/library/\"]').forEach(el => {\n      adLinks.push({\n        href: el.getAttribute('href'),\n        text: (el.textContent || '').substring(0, 80),\n      });\n    });\n    results.adLinks = adLinks.slice(0, 10);\n\n    return results;\n  });\n\n  console.log(JSON.stringify(info, null, 2));\n  \n  // Save full HTML of first few ads\n  const htmlSnippet = await page.evaluate(() => {\n    const allDivs = document.querySelectorAll('div');\n    let result = '';\n    for (let i = 0; i < allDivs.length; i++) {\n      const d = allDivs[i];\n      const text = d.textContent || '';\n      if (text.includes('Sponsored') && text.includes('See ad details') && text.length < 5000) {\n        result += `\\n=== DIV ${i} ===\\n${d.outerHTML.substring(0, 2000)}\\n`;\n        if (result.length > 10000) break;\n      }\n    }\n    return result;\n  });\n  \n  fs.writeFileSync('./temp/debug_html.txt', htmlSnippet);\n  console.log('\\n\\nHTML dump saved to temp/debug_html.txt');\n\n  await browser.close();\n  console.log('Done');\n})();\n"
