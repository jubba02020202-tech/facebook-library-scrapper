395: function escapeHtml(str) {
396:   if (!str) return '';
397:   const div = document.createElement('div');
398:   div.textContent = str;
399:   return div.innerHTML;
400: }
401: 
402: function truncateUrl(url, max = 50) {
403:   return url.length > max ? url.substring(0, max) + '...' : url;
404: }
405: 
406: function showToast(type, message) {
407:   const container = document.getElementById('toastContainer') || (() => {
408:     const c = document.createElement('div');
409:     c.id = 'toastContainer';
410:     c.style.cssText = 'position:fixed;top:20px;right:20px;z-index:9999';
411:     document.body.appendChild(c);
412:     return c;
413:   })();
414: 
415:   const types = {
416:     success: { icon: 'bi-check-circle-fill', bg: 'bg-success' },
417:     danger: { icon: 'bi-exclamation-triangle-fill', bg: 'bg-danger' },
418:     warning: { icon: 'bi-exclamation-circle-fill', bg: 'bg-warning text-dark' },
419:     info: { icon: 'bi-info-circle-fill', bg: 'bg-info text-dark' },
420:   };
421: 
422:   const t = types[type] || types.info;
423:   const toast = document.createElement('div');
424:   toast.className = `toast align-items-center text-white ${t.bg} border-0 show`;
425:   toast.role = 'alert';
426:   toast.innerHTML = `
427:     <div class="d-flex">
428:       <div class="toast-body">
429:         <i class="bi ${t.icon} me-2"></i>${escapeHtml(message)}
430:       </div>
431:       <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
432:     </div>`;
433:   container.appendChild(toast);
434: 
435:   setTimeout(() => {
436:     toast.remove();
437:   }, 5000);
438: }
