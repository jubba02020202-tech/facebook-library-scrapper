44: function handleProgress(data) {
45:   const progressBar = document.getElementById('progressBar');
46:   const progressPercent = document.getElementById('progressPercent');
47:   const progressLabel = document.getElementById('progressLabel');
48:   const progressDetail = document.getElementById('progressDetail');
49: 
50:   document.getElementById('progressSection').style.display = 'block';
51: 
52:   const pct = Math.min(100, data.progress || 0);
53:   progressBar.style.width = pct + '%';
54:   progressBar.setAttribute('aria-valuenow', pct);
55:   progressPercent.textContent = pct + '%';
56: 
57:   if (data.step === 'facebook') {
58:     progressLabel.textContent = 'Scrolling Facebook Ads Library...';
59:     progressDetail.textContent = `Found ${data.adsFound || 0} ads (scroll ${data.scrolls || 0})`;
60:   } else if (data.step === 'facebook_details') {
61:     progressLabel.textContent = 'Opening ads for details...';
62:     progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated bg-warning';
63:     progressDetail.textContent = `Opening ad ${data.current || 0}/${data.total || 0} (${data.adsFound || 0} extracted)`;
64:   } else if (data.step === 'facebook_done') {
65:     progressLabel.textContent = 'Facebook Ads Scanned';
66:     progressBar.className = 'progress-bar bg-success';
67:     progressDetail.textContent = data.message || '';
68:   } else if (data.step === 'crawling') {
69:     progressLabel.textContent = 'Visiting Websites...';
70:     progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated bg-info';
71:     progressDetail.textContent = `${data.message || ''}`;
72:   } else if (data.step === 'completed') {
73:     progressLabel.textContent = 'Extraction Complete!';
74:     progressBar.className = 'progress-bar bg-success';
75:     progressDetail.textContent = data.message || 'Done!';
76: 
77:     document.getElementById('startBtn').disabled = false;
78:     document.getElementById('startBtn').innerHTML = '<i class="bi bi-play-fill me-1"></i>Start Extraction';
79: 
80:     if (data.results) {
81:       currentData = data.results;
82:       displayResults(data.results, data.totalBusinesses, data.totalPhones);
83:     }
84:   } else if (data.step === 'error') {
85:     progressLabel.textContent = 'Error';
86:     progressBar.className = 'progress-bar bg-danger';
87:     progressDetail.textContent = data.message || 'An error occurred';
88:     document.getElementById('startBtn').disabled = false;
89:     document.getElementById('startBtn').innerHTML = '<i class="bi bi-play-fill me-1"></i>Start Extraction';
90:   }
91: }
92: 
93: async function startExtraction() {
94:   const urlInput = document.getElementById('adsUrl');
95:   const url = urlInput.value.trim();
96: 
97:   if (!url) {
98:     showToast('warning', 'Please enter a Facebook Ads Library URL');
99:     urlInput.focus();
100:     return;
101:   }
102: 
103:   const btn = document.getElementById('startBtn');
104:   btn.disabled = true;
105:   btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Extracting...';
106: 
107:   document.getElementById('progressSection').style.display = 'block';
108:   document.getElementById('statsSection').style.display = 'none';
109:   document.getElementById('tableSection').style.display = 'none';
110:   document.getElementById('exportSection').style.display = 'none';
111: 
112:   const progressBar = document.getElementById('progressBar');
113:   progressBar.style.width = '0%';
114:   progressBar.className = 'progress-bar progress-bar-striped progress-bar-animated';
115:   document.getElementById('progressPercent').textContent = '0%';
116:   document.getElementById('progressLabel').textContent = 'Starting...';
117:   document.getElementById('progressDetail').textContent = '';
118: 
119:   try {
120:     const response = await fetch('/api/extract', {
121:       method: 'POST',
122:       headers: { 'Content-Type': 'application/json' },
123:       body: JSON.stringify({ url }),
124:     });
125: 
126:     const result = await response.json();
127: 
128:     if (!response.ok) {
129:       showToast('danger', result.error || 'Failed to start extraction');
130:       btn.disabled = false;
131:       btn.innerHTML = '<i class="bi bi-play-fill me-1"></i>Start Extraction';
132:       return;
133:     }
134: 
135:     currentSessionId = result.sessionId;
136:     showToast('success', 'Extraction started! Session: ' + currentSessionId);
137:     loadSessions();
138: 
139:   } catch (err) {
140:     showToast('danger', 'Network error: ' + err.message);
141:     btn.disabled = false;
142:     btn.innerHTML = '<i class="bi bi-play-fill me-1"></i>Start Extraction';
143:   }
144: }
145: 
146: async function pollStatus(sessionId) {
147:   try {
148:     const response = await fetch(`/api/status/${sessionId}`);
149:     if (!response.ok) return;
150: 
151:     const data = await response.json();
152: 
153:     if (data.status === 'completed') {
154:       currentData = data.results || [];
155:       displayResults(currentData, data.totalBusinesses, data.totalPhones);
156:       document.getElementById('startBtn').disabled = false;
157:       document.getElementById('startBtn').innerHTML = '<i class="bi bi-play-fill me-1"></i>Start Extraction';
158:     }
159:   } catch (e) {}
160: }
161: 
162: function displayResults(results, totalBusinesses, totalPhones) {
163:   currentData = results || [];
164:   filteredData = [...currentData];
165:   currentPage = 1;
166: 
167:   document.getElementById('statsSection').style.display = 'block';
168:   document.getElementById('tableSection').style.display = 'block';
169: 
170:   document.getElementById('totalBusinesses').textContent = totalBusinesses || 0;
171: 
172:   const phonesCount = totalPhones || 0;
173:   document.getElementById('totalPhones').textContent = phonesCount;
174: 
175:   const withPhones = results ? results.filter(r => r.phones && r.phones.length > 0).length : 0;
176:   document.getElementById('totalWithPhones').textContent = withPhones;
177: 
178:   const errors = results ? results.filter(r => r.error).length : 0;
179:   document.getElementById('totalErrors').textContent = errors;
180: 
181:   if (results && results.length > 0) {
182:     document.getElementById('exportSection').style.display = 'block';
183:   }
184: 
185:   filterTable();
186:   loadSessions();
187: }
188: 
189: function filterTable() {
190:   const searchTerm = document.getElementById('searchInput').value.toLowerCase().trim();
191:   const phoneFilter = document.getElementById('filterPhones').value;
192: 
193:   filteredData = currentData.filter((row) => {
194:     if (phoneFilter === 'withPhones' && (!row.phones || row.phones.length === 0)) return false;
195:     if (phoneFilter === 'withoutPhones' && row.phones && row.phones.length > 0) return false;
196: 
197:     if (searchTerm) {
198:       const searchable = [
199:         row.businessName, row.pageName, row.websiteUrl, row.cta,
200:         ...(row.phones || []),
201:       ].join(' ').toLowerCase();
202:       return searchable.includes(searchTerm);
203:     }
204: 
205:     return true;
206:   });
207: 
208:   currentPage = 1;
209:   renderTable();
210: }
211: 
212: function renderTable() {
213:   const pageSizeSelect = document.getElementById('pageSize');
214:   pageSize = parseInt(pageSizeSelect.value, 10);
215: 
216:   const total = filteredData.length;
217:   const totalPages = Math.ceil(total / pageSize) || 1;
218:   const start = (currentPage - 1) * pageSize;
219:   const end = Math.min(start + pageSize, total);
220:   const pageData = filteredData.slice(start, end);
221: 
222:   document.getElementById('resultCount').textContent = total;
223: 
224:   const tbody = document.getElementById('tableBody');
225:   tbody.innerHTML = '';
226: 
227:   if (pageData.length === 0) {
228:     tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-4">No results found</td></tr>';
229:     renderPagination(1, 0);
230:     return;
231:   }
232: 
233:   let sorted = [...pageData];
234:   if (sortColumn) {
235:     sorted.sort((a, b) => {
236:       let va = (a[sortColumn] || '').toString().toLowerCase();
237:       let vb = (b[sortColumn] || '').toString().toLowerCase();
238:       if (sortDirection === 'asc') return va.localeCompare(vb);
239:       return vb.localeCompare(va);
240:     });
241:   }
242: 
243:   sorted.forEach((row) => {
244:     const tr = document.createElement('tr');
245: 
246:     const hasPhones = row.phones && row.phones.length > 0;
247:     const hasWhatsApp = row.whatsappLinks && row.whatsappLinks.length > 0;
248: 
249:     tr.innerHTML = `
250:       <td><strong>${escapeHtml(row.businessName || '—')}</strong></td>
251:       <td>${escapeHtml(row.pageName || '—')}</td>
252:       <td>
253:         ${row.websiteUrl ? `<a href="${escapeHtml(row.websiteUrl)}" target="_blank" class="text-info text-break">${escapeHtml(truncateUrl(row.websiteUrl))}</a>` : '<span class="text-muted">—</span>'}
254:       </td>
255:       <td>${row.cta ? `<span class="badge bg-primary">${escapeHtml(row.cta)}</span>` : '—'}</td>
256:       <td>
257:         ${hasPhones ? row.phones.map(p => `<span class="phone-badge">${escapeHtml(p)}</span>`).join('') : '<span class="text-muted">—</span>'}
258:       </td>
259:       <td>
260:         ${hasWhatsApp ? row.whatsappLinks.map(w => `<a href="${escapeHtml(w.link)}" target="_blank" class="whatsapp-badge"><i class="bi bi-whatsapp me-1"></i>WA</a>`).join('') : '<span class="text-muted">—</span>'}
261:       </td>
262:       <td>
263:         ${row.error ? `<span class="error-cell"><i class="bi bi-exclamation-triangle me-1"></i>Error</span>` : '<span class="text-success"><i class="bi bi-check-circle"></i></span>'}
264:       </td>
265:     `;
266:     tbody.appendChild(tr);
267:   });
268: 
269:   renderPagination(currentPage, totalPages);
270: }
271: 
272: function renderPagination(current, total) {
273:   const ul = document.getElementById('pagination');
274:   ul.innerHTML = '';
275: 
276:   if (total <= 1) return;
277: 
278:   const addPage = (page, label, active) => {
279:     const li = document.createElement('li');
280:     li.className = `page-item ${active ? 'active' : ''} ${page < 1 || page > total ? 'disabled' : ''}`;
281:     const a = document.createElement('a');
282:     a.className = 'page-link';
283:     a.href = '#';
284:     a.textContent = label;
285:     a.onclick = (e) => {
286:       e.preventDefault();
287:       if (page >= 1 && page <= total) {
288:         currentPage = page;
289:         renderTable();
290:       }
291:     };
292:     li.appendChild(a);
293:     ul.appendChild(li);
294:   };
295: 
296:   addPage(current - 1, '«');
297:   for (let i = Math.max(1, current - 2); i <= Math.min(total, current + 2); i++) {
298:     addPage(i, i, i === current);
299:   }
300:   addPage(current + 1, '»');
301: }
302: 
303: function sortTable(column) {
304:   if (sortColumn === column) {
305:     sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
306:   } else {
307:     sortColumn = column;
308:     sortDirection = 'asc';
309:   }
310:   renderTable();
311: }
312: 
313: async function exportExcel() {
314:   if (!currentSessionId) {
315:     showToast('warning', 'No data to export');
316:     return;
317:   }
318: 
319:   try {
320:     const response = await fetch(`/api/export/${currentSessionId}`);
321:     if (!response.ok) {
322:       const err = await response.json();
323:       showToast('danger', err.error || 'Export failed');
324:       return;
325:     }
326: 
327:     const blob = await response.blob();
328:     const url = window.URL.createObjectURL(blob);
329:     const a = document.createElement('a');
330:     a.href = url;
331:     a.download = `leads-${currentSessionId}.xlsx`;
332:     document.body.appendChild(a);
333:     a.click();
334:     document.body.removeChild(a);
335:     window.URL.revokeObjectURL(url);
336:     showToast('success', 'Excel file downloaded!');
337:   } catch (err) {
338:     showToast('danger', 'Export error: ' + err.message);
339:   }
340: }
341: 
342: async function loadSessions() {
343:   try {
344:     const response = await fetch('/api/sessions');
345:     const data = await response.json();
346:     const div = document.getElementById('sessionsList');
347: 
348:     if (!data.sessions || data.sessions.length === 0) {
349:       div.innerHTML = '<p class="text-muted small mb-0">No sessions yet</p>';
350:       return;
351:     }
352: 
353:     let html = '<div class="list-group list-group-flush">';
354:     data.sessions.slice(0, 10).forEach((s) => {
355:       const time = new Date(s.createdAt).toLocaleString();
356:       const statusBadge = s.status === 'completed' ? 'bg-success' :
357:         s.status === 'error' ? 'bg-danger' : 'bg-warning';
358:       html += `
359:         <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center
360:           ${s.id === currentSessionId ? 'active' : ''}"
361:           onclick="if('${s.status}'==='completed'){ loadSession('${s.id}'); }"
362:           style="cursor:${s.status === 'completed' ? 'pointer' : 'default'}">
363:           <div>
364:             <small class="text-muted">${time}</small>
365:             <span class="badge ${statusBadge} ms-2">${s.status}</span>
366:             ${s.id === currentSessionId ? '<span class="badge bg-primary ms-1">Current</span>' : ''}
367:           </div>
368:           <div class="text-end">
369:             <small>${s.totalBusinesses || 0} businesses</small>
370:             <small class="ms-2">${s.totalPhones || 0} phones</small>
371:           </div>
372:         </div>`;
373:     });
374:     html += '</div>';
375:     div.innerHTML = html;
376:   } catch (e) {}
377: }
378: 
379: async function loadSession(sessionId) {
380:   try {
381:     const response = await fetch(`/api/status/${sessionId}`);
382:     const data = await response.json();
383:     if (data.status === 'completed' && data.results) {
384:       currentSessionId = sessionId;
385:       currentData = data.results;
386:       displayResults(data.results, data.totalBusinesses, data.totalPhones);
387:       document.getElementById('adsUrl').value = '';
388:       showToast('info', `Loaded session ${sessionId}`);
389:     }
390:   } catch (e) {
391:     showToast('danger', 'Failed to load session');
392:   }
393: }
